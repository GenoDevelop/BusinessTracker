<UserControl x:Class="GenoDev.BusinessTracker.Wpf.Infrastructure.Controls.DateRangePicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             x:Name="Root">
    <Grid>
        <ToggleButton x:Name="DateRangeToggle" HorizontalContentAlignment="Stretch" Background="White" Padding="10,2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding StartDate, ElementName=Root, StringFormat='dd.MM.yyyy'}" />
                    <TextBlock Text=" - " Visibility="{Binding EndDate, ElementName=Root, Converter={StaticResource NullToAllConverter}, ConverterParameter='Visible;Collapsed'}" />
                    <TextBlock Text="{Binding EndDate, ElementName=Root, StringFormat='dd.MM.yyyy'}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="✕" 
                            Visibility="{Binding StartDate, ElementName=Root, Converter={StaticResource NullToAllConverter}, ConverterParameter='Visible;Collapsed'}"
                            Click="ClearButton_Click" 
                            Margin="0,0,3,0"
                            Background="Transparent" BorderThickness="0" 
                            VerticalAlignment="Center" Cursor="Hand"
                            ToolTip="Clear Selection"/>
                    <Path Data="M19,19H5V8H19M16,1V3H8V1H6V3H5C3.89,3 3,3.89 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5C21,3.89 20.1,3 19,3H18V1M17,12H12V17H17V12Z" 
                          Fill="Gray" Stretch="Uniform" Width="16" Height="16" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </ToggleButton>
        <Popup IsOpen="{Binding IsChecked, ElementName=DateRangeToggle}" PlacementTarget="{Binding ElementName=DateRangeToggle}" StaysOpen="False">
            <Border Background="White" BorderBrush="Gray" BorderThickness="1">
                <Calendar SelectionMode="SingleRange" x:Name="RangeCalendar" SelectedDatesChanged="RangeCalendar_SelectedDatesChanged" />
            </Border>
        </Popup>
    </Grid>
</UserControl>
