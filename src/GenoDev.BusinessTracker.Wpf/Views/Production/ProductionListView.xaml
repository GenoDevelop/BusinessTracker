<UserControl x:Class="GenoDev.BusinessTracker.Wpf.Views.Production.ProductionListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:GenoDev.BusinessTracker.Wpf.ViewModels.Production"
             xmlns:controls="clr-namespace:GenoDev.BusinessTracker.Wpf.Infrastructure.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance vm:ProductionListViewModel}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="5, 5, 2, 5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                <TextBlock Text="Produkcja" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0" />
                <Button Command="{Binding RefreshCommand}" Style="{StaticResource IconButton}" ToolTip="Odśwież" Margin="0,0,5,0">
                    <Path Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z" Fill="DodgerBlue" Stretch="Uniform" Width="18" Height="18" />
                </Button>
                <ToggleButton IsChecked="{Binding IsFilterVisible}" Style="{StaticResource IconToggleButton}" ToolTip="Filtruj">
                    <Path Data="M10,18H14V16H10V18M3,6V8H21V6H3M6,13H18V11H6V13Z" 
                          Fill="Gray" Stretch="Uniform" Width="20" Height="20" />
                </ToggleButton>
            </StackPanel>

            <!-- Search Header -->
            <Border Grid.Row="1" BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="0,0,0,5" Margin="0,0,0,5"
                    Visibility="{Binding IsFilterVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L19.71,19L18.29,20.41L13.01,15.14C11.87,16.11 10.39,16.7 8.75,16.7A6.5,6.5 0 0,1 2.25,10.2A6.5,6.5 0 0,1 8.75,3.7M8.75,5.2A5,5 0 0,0 3.75,10.2A5,5 0 0,0 8.75,15.2A5,5 0 0,0 13.75,10.2A5,5 0 0,0 8.75,5.2Z" 
                              Fill="Gray" Stretch="Uniform" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,5,0" />
                        <TextBox Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged}" Width="150" VerticalContentAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Products List -->
            <ListBox Grid.Row="2" ItemsSource="{Binding Products}" SelectedItem="{Binding SelectedProduct}" BorderThickness="0" Padding="0">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border Background="{TemplateBinding Background}" 
                                            BorderBrush="{TemplateBinding BorderBrush}" 
                                            BorderThickness="{TemplateBinding BorderThickness}" 
                                            Padding="3,2">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#E0EEFF" />
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F0F7FF" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            
                            <!-- Recipes count on the left centered vertically -->
                            <Border Grid.Column="0" VerticalAlignment="Center" Margin="0,0,6,0" Width="10">
                                <TextBlock Text="{Binding RecipesCount}" FontWeight="Bold" FontSize="13" HorizontalAlignment="Center" Foreground="DodgerBlue" />
                            </Border>

                            <StackPanel Grid.Column="1">
                                <!-- ProductName (Identifier) -->
                                <TextBlock FontWeight="Bold" FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center">
                                    <Run Text="{Binding ProductName, Mode=OneWay}" />
                                    <Run Text="(" /><Run Text="{Binding ProductIdentifier, Mode=OneWay}" /><Run Text=")" />
                                </TextBlock>
                                <!-- Stan: [currentAmount/SumOfProduction] -->
                                <TextBlock Foreground="Gray" FontSize="11" TextWrapping="Wrap">
                                    <Run Text="Stan: " /><Run Text="{Binding CurrentAmount, Mode=OneWay}" />
                                    <Run Text="/" />
                                    <Run Text="{Binding HistoricalProductionAmount, Mode=OneWay}" />
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Pagination -->
            <Grid Grid.Row="3" Margin="0,2,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Arrows (Top Row) -->
                <Button Grid.Row="0" Grid.Column="0" Command="{Binding PreviousPageCommand}" Style="{StaticResource IconButton}" ToolTip="Poprzednia">
                    <Path Data="M15.41,16.58L10.83,12L15.41,7.41L14,6L8,12L14,18L15.41,16.58Z" Fill="DodgerBlue" Stretch="Uniform" Width="18" Height="18" />
                </Button>
                <TextBlock Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="11">
                    <Run Text="{Binding DisplayPage, Mode=OneWay}" />
                    <Run Text="/" />
                    <Run Text="{Binding TotalPages, Mode=OneWay}" />
                </TextBlock>
                <Button Grid.Row="0" Grid.Column="2" Command="{Binding NextPageCommand}" Style="{StaticResource IconButton}" ToolTip="Następna">
                    <Path Data="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z" Fill="DodgerBlue" Stretch="Uniform" Width="18" Height="18" />
                </Button>

                <!-- Page Size and Counters (Bottom Row) -->
                <StackPanel Grid.Row="1" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,2,0,0">
                    <TextBlock VerticalAlignment="Center" Text="Na stronie:" FontSize="10" Margin="0,0,3,0" />
                    <ComboBox ItemsSource="{Binding AvailablePageSizes}" SelectedItem="{Binding PageSize}" VerticalAlignment="Center" Width="42" FontSize="10" Height="20" />
                    <TextBlock VerticalAlignment="Center" Margin="8,0,0,0" FontSize="10">
                        <Run Text="Poz.:" />
                        <Run Text="{Binding ItemsRange, Mode=OneWay}" />
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Grid>
        <!-- Right Panel -->
        <Grid Grid.Column="1" Background="#F9F9F9">
            <!-- Empty state -->
            <TextBlock Text="Wybierz produkt z listy, aby zobaczyć szczegóły" 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center" 
                       Foreground="Gray" 
                       FontSize="14"
                       Visibility="{Binding SelectedProduct, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter='Inverse'}" />

            <!-- Details section -->
            <Grid Visibility="{Binding SelectedProduct, Converter={StaticResource NullToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Upper space: Basic Information -->
                <Grid Grid.Row="0" Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,15">
                        <TextBlock FontSize="18" FontWeight="Bold" Foreground="Black" VerticalAlignment="Bottom">
                            <Run Text="{Binding SelectedProduct.ProductName, Mode=OneWay}" />
                            <Run Text="(" /><Run Text="{Binding SelectedProduct.ProductIdentifier, Mode=OneWay}" /><Run Text=")" />
                        </TextBlock>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                            <TextBlock Text="Produkt" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="11" Foreground="Gray"/>
                            <ToggleButton IsChecked="{Binding ShowRecipeDetails}" Style="{StaticResource IconToggleButton}" ToolTip="Przełącz Produkt/Przepis">
                                <Grid>
                                    <Path Data="M17,7H7A5,5 0 0,0 2,12A5,5 0 0,0 7,17H17A5,5 0 0,0 22,12A5,5 0 0,0 17,7M17,15A3,3 0 0,1 14,12A3,3 0 0,1 17,9A3,3 0 0,1 20,12A3,3 0 0,1 17,15Z" 
                                          Fill="DodgerBlue" Stretch="Uniform" Width="30" Height="20" 
                                          Visibility="{Binding ShowRecipeDetails, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    <Path Data="M17,7H7C4.24,7 2,9.24 2,12C2,14.76 4.24,17 7,17H17C19.76,17 22,14.76 22,12C22,9.24 19.76,7 17,7M7,15A3,3 0 0,1 4,12A3,3 0 0,1 7,9A3,3 0 0,1 10,12A3,3 0 0,1 7,15Z" 
                                          Fill="Gray" Stretch="Uniform" Width="30" Height="20">
                                        <Path.Style>
                                            <Style TargetType="Path">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ShowRecipeDetails}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Path.Style>
                                    </Path>
                                </Grid>
                            </ToggleButton>
                            <TextBlock Text="Przepis" VerticalAlignment="Center" Margin="5,0,0,0" FontSize="11" Foreground="Gray"/>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Product Details -->
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <StackPanel Orientation="Vertical" Margin="0,0,0,4">
                                <TextBlock Text="Na stanie:" Foreground="Gray" FontSize="11" Width="100" TextAlignment="Left"/>
                                <TextBlock Text="{Binding SelectedProduct.CurrentAmount}" FontWeight="SemiBold"
                                           TextAlignment="Left" TextWrapping="Wrap" MaxWidth="210"/>
                            </StackPanel>

                            <StackPanel Orientation="Vertical" Margin="0,0,0,4">
                                <TextBlock Text="Suma produkcji:" Foreground="Gray" FontSize="11" Width="100" TextAlignment="Left"/>
                                <TextBlock Text="{Binding SelectedProduct.HistoricalProductionAmount}" FontWeight="SemiBold"
                                           TextAlignment="Left" TextWrapping="Wrap" MaxWidth="210"/>
                            </StackPanel>

                            <StackPanel Orientation="Vertical" Margin="0,0,0,4">
                                <TextBlock Text="Przepisy:" Foreground="Gray" FontSize="11" Width="100" TextAlignment="Left" />
                                <TextBlock Text="{Binding SelectedProduct.RecipesCount}" FontWeight="SemiBold"
                                           TextAlignment="Left" TextWrapping="Wrap" MaxWidth="210" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Description -->
                        <Grid Grid.Column="1" Height="100" VerticalAlignment="Top">
                            <Border BorderBrush="#DDD" BorderThickness="1" Background="White" CornerRadius="3" Padding="8">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <TextBlock TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{Binding SelectedProduct.Description}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ShowRecipeDetails}" Value="True">
                                                        <Setter Property="Text" Value="{Binding SelectedRecipe.Description}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>

                <!-- Separator Line -->
                <Separator Grid.Row="1" Background="#DDD" Margin="15,0" Height="1" />

                <!-- Bottom Section: History and Materials -->
                <Grid Grid.Row="2" Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    
                    <!-- Shared Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <TextBlock Text="Historia Produkcji" FontSize="16" FontWeight="Bold" Margin="0,0,10,0" />
                            <Button Command="{Binding RefreshHistoryCommand}" Style="{StaticResource IconButton}"
                                    ToolTip="Odśwież historię" Margin="0,0,5,0">
                                <Path
                                    Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z"
                                    Fill="DodgerBlue" Stretch="Uniform" Width="16" Height="16" />
                            </Button>
                            <ToggleButton IsChecked="{Binding IsHistoryFilterVisible}" Style="{StaticResource IconToggleButton}" ToolTip="Filtruj historię" Margin="0,0,20,0">
                                <Path Data="M10,18H14V16H10V18M3,6V8H21V6H3M6,13H18V11H6V13Z" 
                                      Fill="Gray" Stretch="Uniform" Width="16" Height="16" />
                            </ToggleButton>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBox Text="{Binding RecipeSearchTerm, UpdateSourceTrigger=PropertyChanged}" 
                                     Width="120" Margin="0,0,5,0" 
                                     VerticalContentAlignment="Center"
                                     ToolTip="Szukaj receptury" />
                            <ComboBox ItemsSource="{Binding ProductRecipes}" 
                                      SelectedItem="{Binding SelectedRecipe}" 
                                      DisplayMemberPath="Name"
                                      Width="170" Margin="0,0,5,0" 
                                      VerticalAlignment="Center" />
                            <Button Command="{Binding AddProductionCommand}" Style="{StaticResource IconButton}" ToolTip="Dodaj produkcję">
                                <Path Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z" Fill="Green" Stretch="Uniform" Width="18" Height="18" />
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Content Section: History Table + Materials OR Add Production Form -->
                    <Grid Grid.Row="1">
                        <!-- History and Materials View -->
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAddingProduction}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsEditingProduction}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Production History Content -->
                            <Grid Grid.Row="0" Grid.Column="0" Margin="0,0,10,0">
                                <DataGrid ItemsSource="{Binding ProductionHistory}" 
                                          SelectedItem="{Binding SelectedProduction}"
                                          AutoGenerateColumns="False" IsReadOnly="True"
                                          BorderThickness="1" BorderBrush="#DDD"
                                          ColumnHeaderStyle="{StaticResource DataGridColumnHeaderStyle}">
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Width="Auto">
                                            <DataGridTemplateColumn.Header>
                                                <StackPanel>
                                                    <TextBlock Text="Data" FontWeight="Bold" Margin="0,0,0,2"/>
                                                    <controls:DateRangePicker StartDate="{Binding DataContext.HistoryFromDateFilter, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                                              EndDate="{Binding DataContext.HistoryToDateFilter, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                                              Visibility="{Binding DataContext.IsHistoryFilterVisible, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                              Width="200" HorizontalAlignment="Left" Margin="0" />
                                                </StackPanel>
                                            </DataGridTemplateColumn.Header>
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding ProductionDate, StringFormat=\{0:yyyy-MM-dd HH:mm\}}" VerticalAlignment="Center" Margin="5,0"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Width="Auto">
                                            <DataGridTemplateColumn.Header>
                                                <StackPanel>
                                                    <TextBlock Text="Ilość" FontWeight="Bold" Margin="0,0,0,2"/>
                                                    <Grid Visibility="{Binding DataContext.IsHistoryFilterVisible, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <ComboBox Grid.Column="0" 
                                                                  ItemsSource="{Binding DataContext.AvailableHistoryOperators, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                                  SelectedItem="{Binding DataContext.HistoryAmountOperatorFilter, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                  DisplayMemberPath="Display"
                                                                  Width="35" Height="18" Margin="0,0,2,0" FontWeight="Normal" Padding="7, -2, 0, 0" VerticalContentAlignment="Center" />
                                                        <TextBox Grid.Column="1" 
                                                                 Text="{Binding DataContext.HistoryAmountFilterText, RelativeSource={RelativeSource AncestorType=DataGrid}, UpdateSourceTrigger=PropertyChanged}" 
                                                                 Margin="0" Width="40" FontWeight="Normal" />
                                                    </Grid>
                                                </StackPanel>
                                            </DataGridTemplateColumn.Header>
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding ProductionAmount}" VerticalAlignment="Center" Margin="5,0"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Width="*">
                                            <DataGridTemplateColumn.Header>
                                                <StackPanel>
                                                    <TextBlock Text="Opis" FontWeight="Bold" Margin="0,0,0,2"/>
                                                    <TextBox Text="{Binding DataContext.HistoryDescriptionFilter, RelativeSource={RelativeSource AncestorType=DataGrid}, UpdateSourceTrigger=PropertyChanged}" 
                                                             Visibility="{Binding DataContext.IsHistoryFilterVisible, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                             Margin="0" FontWeight="Normal" />
                                                </StackPanel>
                                            </DataGridTemplateColumn.Header>
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Description}" TextWrapping="Wrap" MaxHeight="60" Margin="5,0" VerticalAlignment="Center" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        
                                        <DataGridTemplateColumn Header="Akcje" Width="80">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                        <Button Style="{StaticResource IconButton}" ToolTip="Edytuj" Margin="0,0,5,0"
                                                                Command="{Binding DataContext.EditProductionCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                CommandParameter="{Binding}">
                                                            <Path Data="M20.71,7.04C21.1,6.65 21.1,6 20.71,5.63L18.37,3.29C18,2.9 17.35,2.9 16.96,3.29L15.12,5.12L18.87,8.87M3,17.25V21H6.75L17.81,9.93L14.06,6.18L3,17.25Z" Fill="SteelBlue" Stretch="Uniform" Width="14" Height="14" />
                                                        </Button>
                                                        <Button Style="{StaticResource IconButton}" ToolTip="Usuń"
                                                                Command="{Binding DataContext.DeleteProductionCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                CommandParameter="{Binding}">
                                                            <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19V4M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" Fill="LightCoral" Stretch="Uniform" Width="14" Height="14" />
                                                        </Button>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                            <!-- Pagination for Production History -->
                            <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,10,0">
                                <TextBlock VerticalAlignment="Center" Margin="10,0" FontSize="10">
                                    <Run Text="Poz.:" />
                                    <Run Text="{Binding HistoryItemsRange, Mode=OneWay}" />
                                </TextBlock>
                                <TextBlock VerticalAlignment="Center" Margin="10,0" Text="Na stronie:" FontSize="10" />
                                <ComboBox ItemsSource="{Binding AvailablePageSizes}" SelectedItem="{Binding HistoryPageSize}" VerticalAlignment="Center" Width="42" FontSize="10" Height="20" />
                                <Button Command="{Binding PreviousHistoryPageCommand}" Style="{StaticResource IconButton}" Margin="5,0" ToolTip="Poprzednia">
                                    <Path Data="M15.41,16.58L10.83,12L15.41,7.41L14,6L8,12L14,18L15.41,16.58Z" Fill="DodgerBlue" Stretch="Uniform" Width="18" Height="18" />
                                </Button>
                                <TextBlock VerticalAlignment="Center" Margin="10,0" FontSize="11">
                                    <Run Text="{Binding HistoryDisplayPage, Mode=OneWay}" />
                                    <Run Text="/" />
                                    <Run Text="{Binding HistoryTotalPages, Mode=OneWay}" />
                                </TextBlock>
                                <Button Command="{Binding NextHistoryPageCommand}" Style="{StaticResource IconButton}" Margin="5,0" ToolTip="Następna">
                                    <Path Data="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z" Fill="DodgerBlue" Stretch="Uniform" Width="18" Height="18" />
                                </Button>
                            </StackPanel>

                            <!-- Materials List Content -->
                            <Grid Grid.Row="0" Grid.Column="1" Grid.RowSpan="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" FontWeight="Bold" Margin="0,0,0,5" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Użyte materiały" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ShowRecipeDetails}" Value="True">
                                                    <Setter Property="Text" Value="Wymagane materiały" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <ListView Grid.Row="1" ItemsSource="{Binding SelectedMaterials}" BorderThickness="1" BorderBrush="#DDD">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                
                                                <TextBlock Text="{Binding MaterialName}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                                
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="10,0,0,0">
                                                    <TextBlock FontWeight="Bold" Foreground="DodgerBlue">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="{Binding UsedAmount}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListView}, Path=DataContext.ShowRecipeDetails}" Value="True">
                                                                        <Setter Property="Text" Value="{Binding RequiredAmount}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock Text=" " />
                                                    <TextBlock Text="{Binding Unit}" Foreground="Gray" />
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </Grid>

                        <!-- Add/Edit Production Form -->
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAddingProduction}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsEditingProduction}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Vertical" Margin="0,0,0,10">
                                <TextBlock FontSize="14" FontWeight="Bold" Margin="0,0,0,10">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Dodaj nową produkcję" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditingProduction}" Value="True">
                                                    <Setter Property="Text" Value="Edytuj produkcję" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <StackPanel Orientation="Horizontal">
                                    <StackPanel Margin="0,0,20,0">
                                        <TextBlock Text="Ilość produkcji" FontWeight="Bold" Margin="0,0,0,2" />
                                        <TextBox Text="{Binding ProductionAmount, UpdateSourceTrigger=PropertyChanged}" Width="100" IsEnabled="{Binding IsProductionSaved, Converter={StaticResource InverseBooleanConverter}}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,20,0">
                                        <TextBlock Text="Data produkcji" FontWeight="Bold" Margin="0,0,0,2" />
                                        <StackPanel Orientation="Horizontal">
                                            <DatePicker SelectedDate="{Binding ProductionDate, UpdateSourceTrigger=PropertyChanged}" Width="120" IsEnabled="{Binding IsProductionSaved, Converter={StaticResource InverseBooleanConverter}}" />
                                            <TextBox Text="{Binding ProductionDate, StringFormat='HH:mm', UpdateSourceTrigger=PropertyChanged}" Width="60" Margin="5,0,0,0" VerticalContentAlignment="Center" IsEnabled="{Binding IsProductionSaved, Converter={StaticResource InverseBooleanConverter}}" />
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="Opis" FontWeight="Bold" Margin="0,0,0,2" />
                                        <TextBox Text="{Binding ProductionDescription, UpdateSourceTrigger=PropertyChanged}" Width="300" AcceptsReturn="True" TextWrapping="Wrap" Height="60" VerticalScrollBarVisibility="Auto" IsEnabled="{Binding IsProductionSaved, Converter={StaticResource InverseBooleanConverter}}" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding MaterialInputs}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#DDD" BorderThickness="1" Margin="0,0,10,10" Padding="8" Width="220" CornerRadius="4">
                                                <StackPanel>
                                                    <TextBlock FontWeight="Bold" TextWrapping="Wrap" Margin="0,0,0,5">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="Black" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasEnough}" Value="False">
                                                                        <Setter Property="Foreground" Value="Red" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                        <Run Text="{Binding MaterialName, Mode=OneWay}" />
                                                        <LineBreak />
                                                        <Run Text="(" FontSize="10" /><Run Text="{Binding TotalRequiredAmount, Mode=OneWay}" FontSize="10" />
                                                        <Run Text=" / " FontSize="10" /><Run Text="{Binding CurrentStock, Mode=OneWay}" FontSize="10" />
                                                        <Run Text=" " FontSize="10" /><Run Text="{Binding Unit, Mode=OneWay}" FontSize="10" /><Run Text=")" FontSize="10" />
                                                    </TextBlock>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBox Grid.Column="0" Text="{Binding UsedAmount, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding DataContext.IsProductionSaved, RelativeSource={RelativeSource AncestorType=ItemsControl}, Converter={StaticResource InverseBooleanConverter}}" />
                                                        <Button Grid.Column="1" Content="⟳" Command="{Binding ReloadDefaultCommand}" 
                                                                IsEnabled="{Binding IsModified}" Margin="5,0,0,0" Width="25" ToolTip="Przywróć domyślną wartość">
                                                            <Button.Style>
                                                                <Style TargetType="Button">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding DataContext.IsProductionSaved, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Value="True">
                                                                            <Setter Property="IsEnabled" Value="False" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                        </Button>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                                <Button Content="Anuluj" Command="{Binding CancelAddProductionCommand}" Margin="0,0,10,0" Padding="15,5" 
                                        Visibility="{Binding IsProductionSaved, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                                <Button Content="Zamknij" Command="{Binding CancelAddProductionCommand}" Margin="0,0,10,0" Padding="15,5"
                                        Visibility="{Binding IsProductionSaved, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <Button Content="Zapisz Produkcję" Command="{Binding SaveProductionCommand}" Padding="15,5" Background="LightBlue"
                                        Visibility="{Binding IsProductionSaved, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
