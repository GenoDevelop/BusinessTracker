<UserControl x:Class="GenoDev.BusinessTracker.Wpf.Views.Materials.MaterialSuppliesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:GenoDev.BusinessTracker.Wpf.ViewModels.Materials"
             xmlns:controls="clr-namespace:GenoDev.BusinessTracker.Wpf.Infrastructure.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance vm:MaterialSuppliesViewModel}">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Dostawy" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0" />
                <Button Command="{Binding CreateSupplyCommand}" Style="{StaticResource IconButton}" ToolTip="Dodaj dostawę" Margin="0,0,5,0">
                    <Path Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z" Fill="Green" Stretch="Uniform" Width="18" Height="18" />
                </Button>
                <Button Command="{Binding RefreshCommand}" Style="{StaticResource IconButton}" ToolTip="Odśwież" Margin="0,0,5,0">
                    <Path Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z" Fill="DodgerBlue" Stretch="Uniform" Width="18" Height="18" />
                </Button>
                <ToggleButton IsChecked="{Binding IsFilterVisible}" Style="{StaticResource IconToggleButton}" ToolTip="Filtruj">
                    <Path Data="M10,18H14V16H10V18M3,6V8H21V6H3M6,13H18V11H6V13Z" 
                          Fill="Gray" Stretch="Uniform" Width="20" Height="20" />
                </ToggleButton>
            </StackPanel>

            <!-- Date Range Picker -->
            <Grid Grid.Row="1" Margin="0,0,0,5" Visibility="{Binding IsFilterVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <controls:DateRangePicker StartDate="{Binding StartDate}" EndDate="{Binding EndDate}" />
            </Grid>

            <!-- Supplies List -->
            <ListBox Grid.Row="2" ItemsSource="{Binding Supplies}" SelectedItem="{Binding SelectedSupply}" Margin="0,0,0,3" BorderThickness="0" Padding="0">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border Background="{TemplateBinding Background}" 
                                            BorderBrush="{TemplateBinding BorderBrush}" 
                                            BorderThickness="{TemplateBinding BorderThickness}" 
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#E0EEFF" />
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F0F7FF" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name, StringFormat='dd.MM.yyyy'}" FontWeight="Bold" Margin="0,3,0,3" Foreground="SteelBlue" FontSize="13" />
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                        <GroupStyle.ContainerStyle>
                            <Style TargetType="GroupItem">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="GroupItem">
                                            <StackPanel>
                                                <ContentPresenter />
                                                <ItemsPresenter />
                                            </StackPanel>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </GroupStyle.ContainerStyle>
                    </GroupStyle>
                </ListBox.GroupStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <Ellipse Width="8" Height="8" Margin="0,0,5,0" VerticalAlignment="Center"
                                     Fill="{Binding Status, Converter={StaticResource StatusToColorConverter}}" />
                            <StackPanel>
                                <TextBlock Text="{Binding SupplierName}" FontWeight="Bold" />
                                <TextBlock Text="{Binding TotalGrossPrice, StringFormat='{}{0:N2}zł'}" Foreground="Gray" FontSize="11" />
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Create Supply Popup -->
            <Popup IsOpen="{Binding IsCreatePopupOpen}" Placement="Mouse" StaysOpen="True">
                <Border Background="White" BorderBrush="Gray" BorderThickness="1" Padding="20" CornerRadius="5">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.5" />
                    </Border.Effect>
                    <StackPanel Width="400" DataContext="{Binding CreateMaterialSupplyViewModel}">
                        <TextBlock Text="Dodaj dostawę" FontSize="18" FontWeight="Bold" Margin="0,0,0,15" />

                        <TextBlock Text="Dostawca (wymagane):" Margin="0,0,0,5" />
                        <ComboBox ItemsSource="{Binding Suppliers}" SelectedItem="{Binding SelectedSupplier}" DisplayMemberPath="Name" Margin="0,0,0,10" />

                        <TextBlock Text="Data zamówienia:" Margin="0,0,0,5" />
                        <DatePicker SelectedDate="{Binding OrderDate}" Margin="0,0,0,10" />

                        <TextBlock Text="Numer faktury:" Margin="0,0,0,5" />
                        <TextBox Text="{Binding InvoiceNo, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" />

                        <TextBlock Text="Opis:" Margin="0,0,0,5" />
                        <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" 
                                 AcceptsReturn="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" 
                                 Height="100" Margin="0,0,0,20" />

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Anuluj" Command="{Binding CancelCommand}" Margin="0,0,10,0" Padding="15,5" />
                            <Button Content="Zapisz" Command="{Binding SaveCommand}" Padding="15,5" Background="LightBlue" IsDefault="True" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Popup>

            <!-- Edit Supply Popup -->
            <Popup IsOpen="{Binding IsEditPopupOpen}" Placement="Mouse" StaysOpen="True">
                <Border Background="White" BorderBrush="Gray" BorderThickness="1" Padding="20" CornerRadius="5">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.5" />
                    </Border.Effect>
                    <StackPanel Width="400" DataContext="{Binding EditMaterialSupplyViewModel}">
                        <TextBlock Text="Edytuj dostawę" FontSize="18" FontWeight="Bold" Margin="0,0,0,20" />

                        <TextBlock Text="Dostawca" Margin="0,0,0,5" Foreground="Gray" />
                        <ComboBox ItemsSource="{Binding Suppliers}" 
                                  SelectedItem="{Binding SelectedSupplier}" 
                                  DisplayMemberPath="Name" 
                                  Margin="0,0,0,15" />

                        <TextBlock Text="Data zamówienia" Margin="0,0,0,5" Foreground="Gray" />
                        <DatePicker SelectedDate="{Binding OrderDate}" Margin="0,0,0,15" />

                        <TextBlock Text="Status" Margin="0,0,0,5" Foreground="Gray" />
                        <ComboBox ItemsSource="{Binding AvailableStatuses}" 
                                  SelectedItem="{Binding Status}" 
                                  Margin="0,0,0,15" />

                        <TextBlock Text="Numer faktury" Margin="0,0,0,5" Foreground="Gray" />
                        <TextBox Text="{Binding InvoiceNo, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15" />

                        <TextBlock Text="Opis" Margin="0,0,0,5" Foreground="Gray" />
                        <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" 
                                 AcceptsReturn="True" 
                                 Height="80" 
                                 VerticalScrollBarVisibility="Auto" 
                                 TextWrapping="Wrap" 
                                 Margin="0,0,0,20" />

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Anuluj" Command="{Binding CancelCommand}" Width="80" Margin="0,0,10,0" />
                            <Button Content="Zapisz" Command="{Binding SaveCommand}" Width="80" IsDefault="True" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Popup>

            <Popup IsOpen="{Binding IsDeletePopupOpen}" Placement="Mouse" StaysOpen="True">
                <Border Background="White" BorderBrush="Gray" BorderThickness="1" Padding="20">
                    <StackPanel Width="300">
                        <TextBlock Text="Potwierdź usunięcie" FontSize="18" FontWeight="Bold" Margin="0,0,0,15" />
                        <TextBlock Margin="0,0,0,20" TextWrapping="Wrap">
                            <Run Text="Czy na pewno chcesz usunąć dostawę od " />
                            <Run Text="{Binding SelectedSupply.SupplierName, Mode=OneWay}" FontWeight="Bold" />
                            <Run Text=" z dnia " />
                            <Run Text="{Binding SelectedSupply.OrderDate, StringFormat='dd.MM.yyyy', Mode=OneWay}" FontWeight="Bold" />
                            <Run Text="?" />
                        </TextBlock>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Anuluj" Command="{Binding CancelDeleteCommand}" Margin="0,0,10,0" Padding="15,5" />
                            <Button Content="Usuń" Command="{Binding ConfirmDeleteCommand}" Padding="15,5" Background="LightCoral" IsDefault="True" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Popup>

            <!-- Pagination -->
            <Grid Grid.Row="3" Margin="0,5,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Arrows (Top Row) -->
                <Button Grid.Row="0" Grid.Column="0" Command="{Binding PreviousPageCommand}" Style="{StaticResource IconButton}" ToolTip="Poprzednia">
                    <Path Data="M15.41,16.58L10.83,12L15.41,7.41L14,6L8,12L14,18L15.41,16.58Z" Fill="DodgerBlue" Stretch="Uniform" Width="18" Height="18" />
                </Button>
                <TextBlock Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="11">
                    <Run Text="{Binding DisplayPage, Mode=OneWay}" />
                    <Run Text="/" />
                    <Run Text="{Binding TotalPages, Mode=OneWay}" />
                </TextBlock>
                <Button Grid.Row="0" Grid.Column="2" Command="{Binding NextPageCommand}" Style="{StaticResource IconButton}" ToolTip="Następna">
                    <Path Data="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z" Fill="DodgerBlue" Stretch="Uniform" Width="18" Height="18" />
                </Button>

                <!-- Page Size and Counters (Bottom Row) -->
                <StackPanel Grid.Row="1" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,-5">
                    <TextBlock VerticalAlignment="Center" Text="Na stronie:" FontSize="11" Margin="0,0,5,0" />
                    <ComboBox ItemsSource="{Binding AvailablePageSizes}" SelectedItem="{Binding PageSize}" VerticalAlignment="Center" Width="45" FontSize="11" Height="22" />
                    <TextBlock VerticalAlignment="Center" Margin="10,0,0,0" FontSize="11">
                        <Run Text="Poz.:" />
                        <Run Text="{Binding ItemsRange, Mode=OneWay}" />
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Right Panel -->
        <Grid Grid.Column="1" Background="#F9F9F9" Margin="10,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Upper space: Basic Information -->
            <Grid Grid.Row="0" Margin="15" Visibility="{Binding SelectedSupplyDetails, Converter={StaticResource NullToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Header: [OrderDate] Supplier Name and Delete Button -->
                <Grid Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,15">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontSize="18" FontWeight="Bold" Foreground="Gray" VerticalAlignment="Bottom">
                            <Run Text="[" /><Run Text="{Binding SelectedSupplyDetails.OrderDate, StringFormat='dd.MM.yyyy'}" /><Run Text="]" />
                        </TextBlock>
                        <TextBlock Text="{Binding SelectedSupplyDetails.SupplierName}" FontWeight="Bold" FontSize="18" Margin="10,0,0,0" Foreground="Black" VerticalAlignment="Bottom"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                        <Button Command="{Binding EditSupplyCommand}" 
                                Style="{StaticResource IconButton}" 
                                Margin="0,0,10,0"
                                ToolTip="Edytuj dostawę">
                            <Path Data="M20.71,7.04C21.1,6.65 21.1,6 20.71,5.63L18.37,3.29C18,2.9 17.35,2.9 16.96,3.29L15.12,5.12L18.87,8.87M3,17.25V21H6.75L17.81,9.93L14.06,6.18L3,17.25Z" 
                                  Fill="SteelBlue" Stretch="Uniform" Width="20" Height="20" />
                        </Button>
                        
                        <Button Command="{Binding DeleteSupplyCommand}" 
                                Style="{StaticResource IconButton}" 
                                ToolTip="Usuń dostawę">
                            <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" 
                                  Fill="IndianRed" Stretch="Uniform" Width="20" Height="20" />
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Status, Prices, Invoice Number -->
                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,30,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Status:" Foreground="Gray" FontSize="11" Width="100"/>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,5,0"
                                     Fill="{Binding SelectedSupplyDetails.Status, Converter={StaticResource StatusToColorConverter}}" />
                            <TextBlock Text="{Binding SelectedSupplyDetails.Status, Converter={StaticResource MaterialSupplyStatusToTextConverter}}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Cena netto suma:" Foreground="Gray" FontSize="11" Width="100"/>
                        <TextBlock Text="{Binding SelectedSupplyDetails.TotalNetPrice, StringFormat='{}{0:N2} zł'}" FontWeight="SemiBold"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Cena brutto suma:" Foreground="Gray" FontSize="11" Width="100"/>
                        <TextBlock Text="{Binding SelectedSupplyDetails.TotalGrossPrice, StringFormat='{}{0:N2} zł'}" FontWeight="SemiBold" Foreground="SteelBlue"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Numer faktury:" Foreground="Gray" FontSize="11" Width="100"/>
                        <TextBlock Text="{Binding SelectedSupplyDetails.InvoiceNo}" FontWeight="SemiBold"/>
                    </StackPanel>
                </StackPanel>

                <!-- Description -->
                <Grid Grid.Row="1" Grid.Column="1" MaxHeight="100">
                    <Border BorderBrush="#DDD" BorderThickness="1" Background="White" CornerRadius="3" Padding="8">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <TextBlock Text="{Binding SelectedSupplyDetails.Description}" TextWrapping="Wrap" />
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>

            <!-- Separator Line -->
            <Separator Grid.Row="1" Background="#DDD" Margin="15,0" Height="1" 
                       Visibility="{Binding SelectedSupplyDetails, Converter={StaticResource NullToVisibilityConverter}}"/>

            <!-- Bottom Panel: Ordered Materials -->
            <Grid Grid.Row="2" Margin="15" Visibility="{Binding SelectedSupplyDetails, Converter={StaticResource NullToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header for Materials Table -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Zamówione Materiały" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" />

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Command="{Binding RefreshSupplyItemsCommand}" Style="{StaticResource IconButton}" Margin="0,0,5,0" ToolTip="Odśwież">
                            <Path Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z" 
                                  Fill="DodgerBlue" Stretch="Uniform" Width="20" Height="20" />
                        </Button>
                        <ToggleButton IsChecked="{Binding IsItemsFilterVisible}" Style="{StaticResource IconToggleButton}" ToolTip="Filtruj">
                            <Path Data="M14,12V19.88C14.04,20.18 13.94,20.5 13.71,20.71C13.32,21.1 12.69,21.1 12.3,20.71L10.29,18.7C10.06,18.47 9.96,18.16 10,17.87V12H9.97L4.21,4.62C3.87,4.19 3.95,3.56 4.38,3.22C4.57,3.08 4.78,3 5,3H19C19.55,3 20,3.45 20,4C20,4.22 19.92,4.43 19.79,4.62L14.03,12H14Z" 
                                  Fill="SteelBlue" Stretch="Uniform" Width="20" Height="20" />
                        </ToggleButton>
                    </StackPanel>
                </Grid>

                <!-- Materials DataGrid -->
                <DataGrid Grid.Row="1" ItemsSource="{Binding SupplyItems}" AutoGenerateColumns="False" IsReadOnly="True"
                          Background="White" BorderThickness="1" BorderBrush="#DDD"
                          ColumnHeaderStyle="{StaticResource DataGridColumnHeaderStyle}"
                          Sorting="DataGrid_Sorting">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="2*" SortMemberPath="MaterialName">
                            <DataGridTemplateColumn.Header>
                                <StackPanel>
                                    <TextBlock Text="Materiał" FontWeight="Bold" Margin="0,0,0,2"/>
                                    <TextBox Text="{Binding DataContext.ItemMaterialNameFilter, RelativeSource={RelativeSource AncestorType=DataGrid}, UpdateSourceTrigger=PropertyChanged}" 
                                             Visibility="{Binding DataContext.IsItemsFilterVisible, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BooleanToVisibilityConverter}}"
                                             Margin="0" FontWeight="Normal" />
                                </StackPanel>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding MaterialName}" VerticalAlignment="Center" Margin="5,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Width="1*" SortMemberPath="Ean">
                            <DataGridTemplateColumn.Header>
                                <StackPanel>
                                    <TextBlock Text="EAN" FontWeight="Bold" Margin="0,0,0,2"/>
                                    <TextBox Text="{Binding DataContext.ItemEanFilter, RelativeSource={RelativeSource AncestorType=DataGrid}, UpdateSourceTrigger=PropertyChanged}" 
                                             Visibility="{Binding DataContext.IsItemsFilterVisible, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BooleanToVisibilityConverter}}"
                                             Margin="0" FontWeight="Normal" />
                                </StackPanel>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Ean}" VerticalAlignment="Center" Margin="5,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Width="Auto" SortMemberPath="SetsAmount">
                            <DataGridTemplateColumn.Header>
                                <StackPanel>
                                    <TextBlock Text="Ilość (zest.)" FontWeight="Bold" Margin="0,0,0,2"/>
                                    <Grid Visibility="{Binding DataContext.IsItemsFilterVisible, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox Grid.Column="0" 
                                                  ItemsSource="{Binding DataContext.AvailableOperators, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                  SelectedItem="{Binding DataContext.SelectedItemSetsAmountOperator, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                  DisplayMemberPath="Display"
                                                  Width="35" Height="18" Margin="0,0,2,0" FontWeight="Normal" Padding="7, -2, 0, 0" VerticalContentAlignment="Center" />
                                        <TextBox Grid.Column="1" 
                                                 Text="{Binding DataContext.ItemSetsAmountFilter, RelativeSource={RelativeSource AncestorType=DataGrid}, UpdateSourceTrigger=PropertyChanged}" 
                                                 IsEnabled="{Binding DataContext.IsItemSetsAmountFilterEnabled, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                 Margin="0" FontWeight="Normal" />
                                    </Grid>
                                </StackPanel>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding SetsAmount}" VerticalAlignment="Center" Margin="5,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Width="Auto" SortMemberPath="Unit">
                            <DataGridTemplateColumn.Header>
                                <StackPanel>
                                    <TextBlock Text="Jedn." FontWeight="Bold" Margin="0,0,0,2"/>
                                    <TextBox Text="{Binding DataContext.ItemUnitFilter, RelativeSource={RelativeSource AncestorType=DataGrid}, UpdateSourceTrigger=PropertyChanged}" 
                                             Visibility="{Binding DataContext.IsItemsFilterVisible, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BooleanToVisibilityConverter}}"
                                             Margin="0" FontWeight="Normal" />
                                </StackPanel>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Unit}" VerticalAlignment="Center" Margin="5,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Width="Auto" SortMemberPath="UnitsInSet">
                            <DataGridTemplateColumn.Header>
                                <StackPanel>
                                    <TextBlock Text="Szt. w zest." FontWeight="Bold" Margin="0,0,0,2"/>
                                    <Grid Visibility="{Binding DataContext.IsItemsFilterVisible, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox Grid.Column="0" 
                                                  ItemsSource="{Binding DataContext.AvailableOperators, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                  SelectedItem="{Binding DataContext.SelectedItemUnitsInSetOperator, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                  DisplayMemberPath="Display"
                                                  Width="35" Height="18" Margin="0,0,2,0" FontWeight="Normal" Padding="7, -2, 0, 0" VerticalContentAlignment="Center" />
                                        <TextBox Grid.Column="1" 
                                                 Text="{Binding DataContext.ItemUnitsInSetFilter, RelativeSource={RelativeSource AncestorType=DataGrid}, UpdateSourceTrigger=PropertyChanged}" 
                                                 IsEnabled="{Binding DataContext.IsItemUnitsInSetFilterEnabled, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                 Margin="0" FontWeight="Normal" />
                                    </Grid>
                                </StackPanel>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding UnitsInSet}" VerticalAlignment="Center" Margin="5,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        
                        <DataGridTemplateColumn Width="Auto" SortMemberPath="SetNetPrice">
                            <DataGridTemplateColumn.Header>
                                <StackPanel>
                                    <TextBlock Text="Cena netto" FontWeight="Bold" Margin="0,0,0,2"/>
                                    <Grid Visibility="{Binding DataContext.IsItemsFilterVisible, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox Grid.Column="0" 
                                                  ItemsSource="{Binding DataContext.AvailableOperators, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                  SelectedItem="{Binding DataContext.SelectedItemSetNetPriceOperator, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                  DisplayMemberPath="Display"
                                                  Width="35" Height="18" Margin="0,0,2,0" FontWeight="Normal" Padding="7, -2, 0, 0" VerticalContentAlignment="Center" />
                                        <TextBox Grid.Column="1" 
                                                 Text="{Binding DataContext.ItemSetNetPriceFilter, RelativeSource={RelativeSource AncestorType=DataGrid}, UpdateSourceTrigger=PropertyChanged}" 
                                                 IsEnabled="{Binding DataContext.IsItemSetNetPriceFilterEnabled, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                 Margin="0" FontWeight="Normal" />
                                    </Grid>
                                </StackPanel>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding SetNetPrice, StringFormat='{}{0:N2} zł'}" VerticalAlignment="Center" Margin="5,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Width="Auto" SortMemberPath="TotalNetPrice">
                            <DataGridTemplateColumn.Header>
                                <StackPanel>
                                    <TextBlock Text="Suma netto" FontWeight="Bold" Margin="0,0,0,2"/>
                                    <Grid Visibility="{Binding DataContext.IsItemsFilterVisible, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox Grid.Column="0" 
                                                  ItemsSource="{Binding DataContext.AvailableOperators, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                  SelectedItem="{Binding DataContext.SelectedItemTotalNetPriceOperator, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                  DisplayMemberPath="Display"
                                                  Width="35" Height="18" Margin="0,0,2,0" FontWeight="Normal" Padding="7, -2, 0, 0" VerticalContentAlignment="Center" />
                                        <TextBox Grid.Column="1" 
                                                 Text="{Binding DataContext.ItemTotalNetPriceFilter, RelativeSource={RelativeSource AncestorType=DataGrid}, UpdateSourceTrigger=PropertyChanged}" 
                                                 IsEnabled="{Binding DataContext.IsItemTotalNetPriceFilterEnabled, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                 Margin="0" FontWeight="Normal" />
                                    </Grid>
                                </StackPanel>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding TotalNetPrice, StringFormat='{}{0:N2} zł'}" VerticalAlignment="Center" Margin="5,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        
                        <DataGridTemplateColumn Width="Auto" SortMemberPath="SetGrossPrice">
                            <DataGridTemplateColumn.Header>
                                <StackPanel>
                                    <TextBlock Text="Cena brutto" FontWeight="Bold" Margin="0,0,0,2"/>
                                    <Grid Visibility="{Binding DataContext.IsItemsFilterVisible, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox Grid.Column="0" 
                                                  ItemsSource="{Binding DataContext.AvailableOperators, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                  SelectedItem="{Binding DataContext.SelectedItemSetGrossPriceOperator, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                  DisplayMemberPath="Display"
                                                  Width="35" Height="18" Margin="0,0,2,0" FontWeight="Normal" Padding="7, -2, 0, 0" VerticalContentAlignment="Center" />
                                        <TextBox Grid.Column="1" 
                                                 Text="{Binding DataContext.ItemSetGrossPriceFilter, RelativeSource={RelativeSource AncestorType=DataGrid}, UpdateSourceTrigger=PropertyChanged}" 
                                                 IsEnabled="{Binding DataContext.IsItemSetGrossPriceFilterEnabled, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                 Margin="0" FontWeight="Normal" />
                                    </Grid>
                                </StackPanel>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding SetGrossPrice, StringFormat='{}{0:N2} zł'}" VerticalAlignment="Center" Margin="5,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Width="Auto" SortMemberPath="TotalGrossPrice">
                            <DataGridTemplateColumn.Header>
                                <StackPanel>
                                    <TextBlock Text="Suma brutto" FontWeight="Bold" Margin="0,0,0,2"/>
                                    <Grid Visibility="{Binding DataContext.IsItemsFilterVisible, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox Grid.Column="0" 
                                                  ItemsSource="{Binding DataContext.AvailableOperators, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                  SelectedItem="{Binding DataContext.SelectedItemTotalGrossPriceOperator, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                  DisplayMemberPath="Display"
                                                  Width="35" Height="18" Margin="0,0,2,0" FontWeight="Normal" Padding="7, -2, 0, 0" VerticalContentAlignment="Center" />
                                        <TextBox Grid.Column="1" 
                                                 Text="{Binding DataContext.ItemTotalGrossPriceFilter, RelativeSource={RelativeSource AncestorType=DataGrid}, UpdateSourceTrigger=PropertyChanged}" 
                                                 IsEnabled="{Binding DataContext.IsItemTotalGrossPriceFilterEnabled, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                 Margin="0" FontWeight="Normal" />
                                    </Grid>
                                </StackPanel>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding TotalGrossPrice, StringFormat='{}{0:N2} zł'}" VerticalAlignment="Center" Margin="5,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Pagination for Materials -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <TextBlock VerticalAlignment="Center" Margin="10,0">
                        <Run Text="Pozycje:" />
                        <Run Text="{Binding ItemsItemsRange, Mode=OneWay}" />
                    </TextBlock>
                    <TextBlock VerticalAlignment="Center" Margin="10,0" Text="Na stronie:" />
                    <ComboBox ItemsSource="{Binding AvailablePageSizes}" SelectedItem="{Binding ItemsPageSize}" VerticalAlignment="Center" Width="60" />
                    <Button Command="{Binding PreviousItemsPageCommand}" Style="{StaticResource IconButton}" Margin="5,0" ToolTip="Poprzednia">
                        <Path Data="M15.41,16.58L10.83,12L15.41,7.41L14,6L8,12L14,18L15.41,16.58Z" Fill="DodgerBlue" Stretch="Uniform" Width="20" Height="20" />
                    </Button>
                    <TextBlock VerticalAlignment="Center" Margin="10,0">
                        <Run Text="Strona " />
                        <Run Text="{Binding DisplayItemsPage, Mode=OneWay}" />
                        <Run Text=" z " />
                        <Run Text="{Binding TotalItemsPages, Mode=OneWay}" />
                    </TextBlock>
                    <Button Command="{Binding NextItemsPageCommand}" Style="{StaticResource IconButton}" Margin="5,0" ToolTip="Następna">
                        <Path Data="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z" Fill="DodgerBlue" Stretch="Uniform" Width="20" Height="20" />
                    </Button>
                </StackPanel>
            </Grid>

            <TextBlock Text="Wybierz dostawę z listy, aby zobaczyć szczegóły" 
                       HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Gray"
                       Visibility="{Binding SelectedSupplyDetails, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}"/>
        </Grid>
    </Grid>
</UserControl>
