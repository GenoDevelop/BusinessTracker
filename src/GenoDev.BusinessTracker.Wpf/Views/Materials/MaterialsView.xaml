<UserControl x:Class="GenoDev.BusinessTracker.Wpf.Views.Materials.MaterialsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GenoDev.BusinessTracker.Wpf.Views.Materials"
             xmlns:vm="clr-namespace:GenoDev.BusinessTracker.Wpf.ViewModels.Materials"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance vm:MaterialsViewModel}">
    <UserControl.Resources>
        <DataTemplate DataType="{x:Type vm:MaterialListViewModel}">
            <local:MaterialListView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SuppliersViewModel}">
            <local:SuppliersView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:MaterialSuppliesViewModel}">
            <local:MaterialSuppliesView />
        </DataTemplate>
    </UserControl.Resources>
    <Grid>
        <TabControl TabStripPlacement="Left" SelectedIndex="{Binding SelectedTabIndex}">
            <TabItem Header="Materiały">
                <ContentControl Content="{Binding MaterialListViewModel}" />
            </TabItem>
            <TabItem Header="Dostawcy">
                <ContentControl Content="{Binding SuppliersViewModel}" />
            </TabItem>
            <TabItem Header="Dostawy">
                <ContentControl Content="{Binding MaterialSuppliesViewModel}" />
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
