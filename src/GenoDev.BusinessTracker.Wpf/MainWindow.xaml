<Window x:Class="GenoDev.BusinessTracker.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:GenoDev.BusinessTracker.Wpf.ViewModels"
        xmlns:views="clr-namespace:GenoDev.BusinessTracker.Wpf.Views"
        mc:Ignorable="d"
        Title="Business Tracker" Height="768" Width="1024"
        d:DataContext="{d:DesignInstance viewModels:MainViewModel}">
    <Window.Resources>
        <DataTemplate DataType="{x:Type viewModels:SalesViewModel}">
            <views:SalesView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:ProductsViewModel}">
            <views:ProductsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:SuppliersViewModel}">
            <views:SuppliersView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:TaxRatesViewModel}">
            <views:TaxRatesView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:ProductSuppliesViewModel}">
            <views:ProductSuppliesView />
        </DataTemplate>
    </Window.Resources>
        <Grid x:Name="MainGrid">
            <TabControl SelectedIndex="{Binding SelectedMainTabIndex}">
                <TabItem Header="Magazyn">
                    <TabControl TabStripPlacement="Left" SelectedIndex="{Binding SelectedWarehouseTabIndex}">
                        <TabItem Header="Produkty">
                            <ContentControl Content="{Binding ProductsViewModel}" />
                        </TabItem>
                        <TabItem Header="Dostawcy">
                            <ContentControl Content="{Binding SuppliersViewModel}" />
                        </TabItem>
                        <TabItem Header="Dostawy">
                            <ContentControl Content="{Binding ProductSuppliesViewModel}" />
                        </TabItem>
                    </TabControl>
                </TabItem>
                <TabItem Header="Sprzedaż">
                    <TabControl TabStripPlacement="Left">
                        <TabItem Header="Sprzedaż">
                            <ContentControl Content="{Binding SalesViewModel}" />
                        </TabItem>
                        <TabItem Header="Stawki podatkowe">
                            <ContentControl Content="{Binding TaxRatesViewModel}" />
                        </TabItem>
                    </TabControl>
                </TabItem>
            </TabControl>

            <Grid Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}">
                <Rectangle Fill="#80000000" />
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="200" Height="20" />
                    <TextBlock Text="Ładowanie..." Foreground="White" HorizontalAlignment="Center" Margin="0,10,0,0" FontSize="18" />
                </StackPanel>
            </Grid>
        </Grid>
</Window>
